{
  "name": "C#",
  "extensions": [".cs", ".csx"],
  
  "keywords": [
    "abstract", "as", "async", "await", "base", "bool", "break",
    "byte", "case", "catch", "char", "checked", "class", "const",
    "continue", "decimal", "default", "delegate", "do", "double",
    "else", "enum", "event", "explicit", "extern", "false",
    "finally", "fixed", "float", "for", "foreach", "goto",
    "if", "implicit", "in", "int", "interface", "internal",
    "is", "lock", "long", "namespace", "new", "null", "object",
    "operator", "out", "override", "params", "private",
    "protected", "public", "readonly", "ref", "return", "sbyte",
    "sealed", "short", "sizeof", "stackalloc", "static",
    "string", "struct", "switch", "this", "throw", "true",
    "try", "typeof", "uint", "ulong", "unchecked", "unsafe",
    "ushort", "using", "virtual", "void", "volatile", "while",
    "add", "alias", "ascending", "async", "await", "by",
    "descending", "dynamic", "equals", "from", "get", "global",
    "group", "into", "join", "let", "orderby", "partial",
    "remove", "select", "set", "value", "var", "when",
    "where", "yield"
  ],
  
  "types": [
    "object", "string", "bool", "byte", "sbyte", "char",
    "decimal", "double", "float", "int", "uint", "nint",
    "nuint", "long", "ulong", "short", "ushort", "void",
    "dynamic", "var", "DateTime", "TimeSpan", "Guid",
    "Uri", "Version", "CultureInfo", "DateTimeOffset",
    "Array", "List", "Dictionary", "HashSet", "Queue",
    "Stack", "LinkedList", "SortedList", "SortedSet",
    "ObservableCollection", "Collection", "ReadOnlyCollection",
    "StringBuilder", "StringReader", "StringWriter",
    "Stream", "FileStream", "MemoryStream", "NetworkStream",
    "StreamReader", "StreamWriter", "BinaryReader", "BinaryWriter",
    "XmlReader", "XmlWriter", "JsonSerializer", "XmlSerializer",
    "HttpClient", "HttpResponseMessage", "HttpRequestMessage",
    "Task", "Task<T>", "ValueTask", "CancellationToken",
    "CancellationTokenSource", "Action", "Func", "Predicate",
    "Converter", "Comparison", "EventHandler", "Exception",
    "InvalidOperationException", "ArgumentNullException",
    "ArgumentException", "FormatException", "OverflowException"
  ],
  
  "builtins": [
    "Console", "WriteLine", "Write", "ReadLine", "Read",
    "WriteKey", "ReadKey", "Debug", "Trace", "Assert",
    "Fail", "WriteIf", "TraceListener", "File", "Directory",
    "Path", "Environment", "GC", "Math", "Random", "Convert",
    "BitConverter", "Buffer", "Array", "Enum", "String",
    "StringBuilder", "DateTime", "TimeSpan", "Guid", "Uri",
    "Version", "CultureInfo", "NumberFormatInfo",
    "DateTimeFormatInfo", "Regex", "Match", "MatchCollection",
    "Group", "GroupCollection", "Capture", "CaptureCollection"
  ],
  
  "preprocessor": [
    "#if", "#else", "#elif", "#endif", "#define", "#undef",
    "#warning", "#error", "#line", "#region", "#endregion",
    "#pragma", "#nullable", "#nullable enable", "#nullable disable",
    "#nullable restore", "#pragma warning", "#pragma checksum"
  ],
  
  "comments": {
    "single": "//",
    "multi_start": "/*",
    "multi_end": "*/"
  },
  
  "brackets": {
    "auto_close": ["(", "[", "{", "\"", "'"]
  },
  
  "indent": {
    "increase": ["{", "(", ":"],
    "decrease": ["}", ")"]
  },
  
  "completions": {
    "if": "if ($1)\n{\n    $2\n}",
    "else": "else\n{\n    $1\n}",
    "else if": "else if ($1)\n{\n    $2\n}",
    "for": "for (int $1 = 0; $1 < $2; $1++)\n{\n    $3\n}",
    "foreach": "foreach ($1 $2 in $3)\n{\n    $4\n}",
    "while": "while ($1)\n{\n    $2\n}",
    "do": "do\n{\n    $1\n} while ($2);",
    "switch": "switch ($1)\n{\n    case $2:\n        $3\n        break;\n    default:\n        $4\n        break;\n}",
    "case": "case $1:\n    $2\n    break;",
    "default": "default:\n    $1\n    break;",
    "try": "try\n{\n    $1\n}\ncatch ($2 ex)\n{\n    $3\n}\nfinally\n{\n    $4\n}",
    "catch": "catch ($1 ex)\n{\n    $2\n}",
    "finally": "finally\n{\n    $1\n}",
    "throw": "throw new $1(\"$2\");",
    "return": "return $1;",
    "class": "public class $1\n{\n    $2\n}",
    "abstract class": "public abstract class $1\n{\n    $2\n}",
    "sealed class": "public sealed class $1\n{\n    $2\n}",
    "static class": "public static class $1\n{\n    $2\n}",
    "interface": "public interface $1\n{\n    $2\n}",
    "struct": "public struct $1\n{\n    $2\n}",
    "enum": "public enum $1\n{\n    $2,\n    $3\n}",
    "record": "public record $1\n{\n    $2\n}",
    "record class": "public record class $1\n{\n    $2\n}",
    "record struct": "public record struct $1\n{\n    $2\n}",
    "method": "public $1 $2($3)\n{\n    $4\n    return $5;\n}",
    "private method": "private $1 $2($3)\n{\n    $4\n    return $5;\n}",
    "static method": "public static $1 $2($3)\n{\n    $4\n    return $5;\n}",
    "async method": "public async Task<$1> $2($3)\n{\n    $4\n    return $5;\n}",
    "async void": "public async void $1($2)\n{\n    $3\n    await $4;\n}",
    "property": "public $1 $2 { get; set; }",
    "property with backing": "private $1 _$2;\npublic $1 $2\n{\n    get { return _$2; }\n    set { _$2 = value; }\n}",
    "auto property": "public $1 $2 { get; set; }",
    "readonly property": "public $1 $2 { get; }",
    "getter": "public $1 Get$2()\n{\n    return this._$3;\n}",
    "setter": "public void Set$1($2 value)\n{\n    this._$3 = value;\n}",
    "constructor": "public $1($2)\n{\n    $3\n}",
    "static constructor": "static $1()\n{\n    $2\n}",
    "destructor": "~$1()\n{\n    $2\n}",
    "main": "public static void Main(string[] args)\n{\n    $1\n}",
    "async main": "public static async Task Main(string[] args)\n{\n    $1\n}",
    "using": "using $1;",
    "namespace": "namespace $1\n{\n    $2\n}",
    "new": "new $1($2)",
    "var": "var $1 = $2;",
    "explicit cast": "($1)$2",
    "is": "if ($1 is $2 $3)\n{\n    $4\n}",
    "as": "$1 as $2",
    "typeof": "typeof($1)",
    "nameof": "nameof($1)",
    "null check": "if ($1 is null)\n{\n    $2\n}",
    "not null": "if ($1 is not null)\n{\n    $2\n}",
    "null coalescing": "$1 ?? $2",
    "null conditional": "$1?.$2",
    "string interpolation": "$\"{$1}\"",
    "verbatim": "@\"$1\"",
    "lambda": "($1) => $2",
    "delegate": "delegate $1 $2($3);",
    "event": "public event $1 $2;",
    "lock": "lock ($1)\n{\n    $2\n}",
    "using block": "using ($1)\n{\n    $2\n}",
    "await": "await $1;",
    "task": "Task.Run(() =>\n{\n    $1\n});",
    "configure await": "await $1.ConfigureAwait(false);",
    "dispose": "$1?.Dispose();",
    "GC collect": "GC.Collect();",
    "attribute": "[$1]\npublic class $2\n{\n    $3\n}",
    "obsolete": "[Obsolete(\"$1\")]",
    "nullable": "$1?",
    "nullable enable": "#nullable enable\n$1\n#nullable restore",
    "generic class": "public class $1<T>\n{\n    private T $2;\n    \n    public $1(T $3)\n    {\n        $2 = $3;\n    }\n}",
    "generic method": "public T $1<T>(T $2)\n{\n    $3\n    return $2;\n}"
  },
  
  "libraries": {
    "using System": "",
    "using System.Collections": "",
    "using System.Collections.Generic": "",
    "using System.Collections.Concurrent": "",
    "using System.Linq": "",
    "using System.Text": "",
    "using System.Threading": "",
    "using System.Threading.Tasks": "",
    "using System.IO": "",
    "using System.Net": "",
    "using System.Net.Http": "",
    "using System.Net.Sockets": "",
    "using System.Xml": "",
    "using System.Xml.Linq": "",
    "using System.Text.Json": "",
    "using System.Text.RegularExpressions": "",
    "using System.Data": "",
    "using System.Data.SqlClient": "-lsystem.data.sqlclient",
    "using System.Data.Common": "",
    "using System.Drawing": "-lsystem.drawing.common",
    "using System.Windows.Forms": "",
    "using System.Web": "",
    "using Microsoft.AspNetCore": "-lmicrosoft.aspnetcore",
    "using Microsoft.AspNetCore.Mvc": "-lmicrosoft.aspnetcore.mvc",
    "using Microsoft.EntityFrameworkCore": "-lmicrosoft.entityframeworkcore",
    "using Microsoft.Extensions.DependencyInjection": "-lmicrosoft.extensions.dependencyinjection",
    "using Microsoft.Extensions.Logging": "-lmicrosoft.extensions.logging",
    "using Microsoft.Extensions.Configuration": "-lmicrosoft.extensions.configuration",
    "using Newtonsoft.Json": "-lnewtonsoft.json",
    "using Newtonsoft.Json.Linq": "-lnewtonsoft.json",
    "using NUnit.Framework": "-lnunit",
    "using Xunit": "-lxunit",
    "using Moq": "-lmoq",
    "using Serilog": "-lserilog",
    "using NLog": "-lnlog",
    "using AutoMapper": "-lautomapper",
    "using FluentValidation": "-lfluentvalidation",
    "using MediatR": "-lmediatr",
    "using Polly": "-lpolly",
    "using Dapper": "-ldapper"
  },
  
  "compile": {
    "build": "dotnet build 2> compile_errors.txt",
    "run": "dotnet run",
    "check": "dotnet build --no-restore /p:WarningsAsErrors=True"
  },
  
  "template": [
    "using System;",
    "",
    "class Program",
    "{",
    "    static void Main(string[] args)",
    "    {",
    "        Console.WriteLine(\"Hello, world!\");",
    "    }",
    "}"
  ],
  
  "help": {
    "short": "C#: F7=Build F8=Run",
    "long": "C# files (.cs)\nF7: Build with dotnet build\nF8: Run with dotnet run\nTab: Auto-completion for C# features"
  }
}