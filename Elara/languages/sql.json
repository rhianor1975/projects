    "JSON_BUILD_ARRAY", "JSON_OBJECT", "JSON_ARRAY",
    "JSONB_BUILD_OBJECT", "JSONB_BUILD_ARRAY"
  ],
  
  "preprocessor": [
    "BEGIN", "COMMIT", "ROLLBACK", "SAVEPOINT", "RELEASE"
  ],
  
  "comments": {
    "single": "--",
    "multi_start": "/*",
    "multi_end": "*/"
  },
  
  "brackets": {
    "auto_close": ["(", "[", "\"", "'"]
  },
  
  "indent": {
    "increase": ["(", "SELECT", "WHERE", "FROM", "JOIN", "UNION", "VALUES", "WITH"],
    "decrease": [")"]
  },
  
  "completions": {
    "SELECT": "SELECT $1\nFROM $2\nWHERE $3\nORDER BY $4;",
    "SELECT *": "SELECT *\nFROM $1\nWHERE $2;",
    "INSERT": "INSERT INTO $1 ($2)\nVALUES ($3);",
    "INSERT multiple": "INSERT INTO $1 ($2)\nVALUES \n    ($3),\n    ($4);",
    "UPDATE": "UPDATE $1\nSET $2 = $3\nWHERE $4;",
    "DELETE": "DELETE FROM $1\nWHERE $2;",
    "CREATE TABLE": "CREATE TABLE $1 (\n    id INT PRIMARY KEY,\n    $2 VARCHAR(255) NOT NULL,\n    $3 INT,\n    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP\n);",
    "CREATE TABLE with FK": "CREATE TABLE $1 (\n    id INT PRIMARY KEY,\n    $2 VARCHAR(255) NOT NULL,\n    $3_id INT,\n    FOREIGN KEY ($3_id) REFERENCES $4(id)\n);",
    "CREATE INDEX": "CREATE INDEX idx_$1 ON $2 ($3);",
    "CREATE VIEW": "CREATE VIEW $1 AS\nSELECT $2\nFROM $3\nWHERE $4;",
    "ALTER TABLE ADD": "ALTER TABLE $1\nADD COLUMN $2 $3;",
    "ALTER TABLE DROP": "ALTER TABLE $1\nDROP COLUMN $2;",
    "ALTER TABLE MODIFY": "ALTER TABLE $1\nMODIFY COLUMN $2 $3;",
    "DROP TABLE": "DROP TABLE $1;",
    "DROP INDEX": "DROP INDEX $1;",
    "JOIN": "SELECT $1\nFROM $2\nINNER JOIN $3 ON $4 = $5\nWHERE $6;",
    "LEFT JOIN": "SELECT $1\nFROM $2\nLEFT JOIN $3 ON $4 = $5\nWHERE $6;",
    "GROUP BY": "SELECT $1, COUNT(*)\nFROM $2\nGROUP BY $1\nHAVING COUNT(*) > $3;",
    "UNION": "SELECT $1 FROM $2\nUNION\nSELECT $3 FROM $4;",
    "CASE": "CASE \n    WHEN $1 THEN $2\n    WHEN $3 THEN $4\n    ELSE $5\nEND",
    "WITH": "WITH $1 AS (\n    SELECT $2\n    FROM $3\n    WHERE $4\n)\nSELECT * FROM $1;",
    "SUBQUERY": "SELECT $1\nFROM $2\nWHERE $3 IN (SELECT $4 FROM $5 WHERE $6);",
    "EXISTS": "SELECT $1\nFROM $2\nWHERE EXISTS (SELECT 1 FROM $3 WHERE $4);",
    "DISTINCT": "SELECT DISTINCT $1\nFROM $2;",
    "ORDER BY": "ORDER BY $1 $2",
    "LIMIT": "LIMIT $1",
    "OFFSET": "OFFSET $1",
    "COUNT": "COUNT($1)",
    "SUM": "SUM($1)",
    "AVG": "AVG($1)",
    "MAX": "MAX($1)",
    "MIN": "MIN($1)"
  },
  
  "libraries": {
    "CREATE TABLE": "",
    "CREATE DATABASE": "",
    "CREATE INDEX": "",
    "CREATE VIEW": "",
    "CREATE PROCEDURE": "",
    "CREATE FUNCTION": "",
    "CREATE TRIGGER": "",
    "CREATE SEQUENCE": ""
  },
  
  "compile": {
    "build": "psql -c 'SELECT 1' 2> compile_errors.txt",
    "run": "psql -f {file}",
    "check": "psql -c 'SELECT 1'"
  },
  
  "template": [
    "-- SQL Example",
    "",
    "SELECT *",
    "FROM users",
    "WHERE active = true",
    "ORDER BY created_at DESC;"
  ],
  
  "help": {
    "short": "SQL: F7=Check F8=Run",
    "long": "SQL files (.sql, .ddl, .dml)\nF7: Check syntax with psql\nF8: Run with psql -f\nTab: Auto-completion for SQL keywords"
  }
}