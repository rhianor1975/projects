{
  "name": "Markdown",
  "extensions": [".md", ".markdown", ".mkd", ".mdown"],
  
  "keywords": [
    "#", "##", "###", "####", "#####", "######", "-", "*",
    ">", "`", "```", "---", "***", "___", "|", "!", "[", "]",
    "(", ")", "{", "}", "[TOC]", "<!--", "-->"
  ],
  
  "types": [],
  
  "builtins": [],
  
  "preprocessor": [],
  
  "comments": {
    "single": "<!--",
    "multi_start": "<!--",
    "multi_end": "-->"
  },
  
  "brackets": {
    "auto_close": ["[", "(", "\"", "'", "`"]
  },
  
  "indent": {
    "increase": [],
    "decrease": []
  },
  
  "completions": {
    "heading 1": "# $1",
    "heading 2": "## $1",
    "heading 3": "### $1",
    "heading 4": "#### $1",
    "heading 5": "##### $1",
    "heading 6": "###### $1",
    "bold": "**$1**",
    "italic": "*$1*",
    "bold italic": "***$1***",
    "strikethrough": "~~$1~~",
    "code": "`$1`",
    "code block": "```$1\n$2\n```",
    "link": "[$1]($2)",
    "image": "![$1]($2)",
    "list": "- $1",
    "numbered list": "1. $1",
    "checkbox": "- [ ] $1",
    "checked": "- [x] $1",
    "quote": "> $1",
    "horizontal rule": "---",
    "table": "| $1 | $2 | $3 |\n| --- | --- | --- |\n| $4 | $5 | $6 |",
    "toc": "[TOC]",
    "html comment": "<!-- $1 -->",
    "definition": "term\n: $1",
    "footnote": "[^$1]",
    "footnote def": "[^$1]: $2",
    "task list": "- [ ] $1\n    - [x] $2",
    "emoji": ":$1:",
    "math": "$$ $1 $$"
  },
  
  "libraries": {},
  
  "compile": {
    "build": "pandoc {file} -o {output}.html 2> compile_errors.txt",
    "run": "pandoc {file} | lynx -stdin",
    "check": "pandoc -f markdown {file}"
  },
  
  "template": [
    "# Hello, world!",
    "",
    "Welcome to my document.",
    "",
    "## Section 1",
    "",
    "Content here..."
  ],
  
  "help": {
    "short": "Markdown: F7=Check F8=Preview",
    "long": "Markdown files (.md, .markdown)\nF7: Check with pandoc\nF8: Preview with pandoc + lynx\nTab: Auto-completion for markdown syntax"
  }
}