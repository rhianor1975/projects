{
  "name": "C",
  "extensions": [".c", ".h"],
  
  "keywords": [
    "auto", "break", "case", "char", "const", "continue",
    "default", "do", "double", "else", "enum", "extern",
    "float", "for", "goto", "if", "int", "long",
    "register", "return", "short", "signed", "sizeof",
    "static", "struct", "switch", "typedef", "union",
    "unsigned", "void", "volatile", "while"
  ],
  
  "types": [
    "int", "char", "float", "double", "void", "long", "short",
    "unsigned", "signed", "struct", "union", "enum", "typedef",
    "size_t", "ssize_t", "int8_t", "int16_t", "int32_t", "int64_t",
    "uint8_t", "uint16_t", "uint32_t", "uint64_t"
  ],
  
  "builtins": [
    "printf", "scanf", "fprintf", "fscanf", "sprintf", "sscanf",
    "malloc", "calloc", "realloc", "free", "exit", "abort",
    "fopen", "fclose", "fread", "fwrite", "fseek", "ftell",
    "feof", "ferror", "getc", "putc", "gets", "puts",
    "strcpy", "strncpy", "strcat", "strncat", "strcmp", "strncmp",
    "strlen", "strchr", "strrchr", "strstr", "strtok",
    "memcpy", "memmove", "memset", "memcmp", "memchr",
    "atoi", "atol", "atof", "strtol", "strtod",
    "rand", "srand", "time", "clock", "system",
    "qsort", "bsearch", "abs", "labs", "div", "ldiv",
    "signal", "raise", "setjmp", "longjmp"
  ],
  
  "preprocessor": [
    "#include", "#define", "#undef", "#ifdef", "#ifndef",
    "#if", "#else", "#elif", "#endif", "#error", "#pragma",
    "#line", "#warning"
  ],
  
  "comments": {
    "single": "//",
    "multi_start": "/*",
    "multi_end": "*/"
  },
  
  "brackets": {
    "auto_close": ["(", "[", "{", "\"", "'"]
  },
  
  "indent": {
    "increase": ["{"],
    "decrease": ["}"]
  },
  
  "completions": {
    "#ifdef": "#ifdef $1\n    $2\n#endif",
    "#ifndef": "#ifndef $1\n    $2\n#endif",
    "#include": "#include <$1>",
    "struct": "struct $1 {\n    $2\n};",
    "typedef": "typedef $1 $2;",
    "enum": "enum $1 {\n    $2\n};",
    "union": "union $1 {\n    $2\n};",
    "switch": "switch ($1) {\n    case $2:\n        $3\n        break;\n    default:\n        $4\n}",
    "case": "case $1:\n    $2\n    break;",
    "default": "default:\n    $1\n    break;",
    "for": "for (int $1 = 0; $1 < $2; $1++) {\n    $3\n}",
    "while": "while ($1) {\n    $2\n}",
    "do": "do {\n    $1\n} while ($2);",
    "if": "if ($1) {\n    $2\n}",
    "else": "else {\n    $1\n}",
    "else if": "else if ($1) {\n    $2\n}",
    "return": "return $1;",
    "main": "int main(int argc, char *argv[]) {\n    $1\n    return 0;\n}"
  },
  
  "libraries": {
    "#include <ncurses.h>": "-lncurses",
    "#include <curses.h>": "-lncurses",
    "initscr(": "-lncurses",
    "endwin(": "-lncurses",
    "#include <math.h>": "-lm",
    "sqrt(": "-lm",
    "pow(": "-lm",
    "sin(": "-lm",
    "cos(": "-lm",
    "tan(": "-lm",
    "#include <pthread.h>": "-lpthread",
    "pthread_create(": "-lpthread",
    "pthread_join(": "-lpthread"
  },
  
  "compile": {
    "build": "gcc -Wall -Wextra -o {output} {file} {libraries} 2> compile_errors.txt",
    "run": "./{output}",
    "error_parser": "gcc"
  },
  
  "template": [
    "#include <stdio.h>",
    "#include <stdlib.h>",
    "",
    "int main(int argc, char *argv[]) {",
    "    ",
    "    return 0;",
    "}"
  ],
  
  "help": {
    "short": "C: F7=Compile F8=Run",
    "long": "C files (.c, .h)\nKeywords, types, and builtins highlighted\nF7: Compile with gcc (auto-detects libraries)\nF8: Run the compiled program\nTab: Auto-completion for keywords and snippets"
  }
}
