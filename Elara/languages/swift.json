{
  "name": "Swift",
  "extensions": [".swift"],
  
  "keywords": [
    "as", "associativity", "break", "case", "catch", "class",
    "continue", "convenience", "default", "defer", "deinit",
    "didSet", "do", "dynamicType", "else", "enum", "extension",
    "fallthrough", "false", "final", "for", "func", "get",
    "guard", "if", "import", "in", "infix", "init", "inout",
    "internal", "is", "left", "let", "mutating", "nil",
    "nonmutating", "open", "operator", "optional", "override",
    "postfix", "precedence", "prefix", "private", "protocol",
    "public", "repeat", "required", "return", "right", "self",
    "set", "static", "struct", "subscript", "super", "switch",
    "throw", "throws", "true", "try", "typealias", "unowned",
    "var", "weak", "where", "while", "willSet"
  ],
  
  "types": [
    "String", "Int", "Int8", "Int16", "Int32", "Int64",
    "UInt", "UInt8", "UInt16", "UInt32", "UInt64",
    "Float", "Double", "Bool", "Character", "Array",
    "Dictionary", "Set", "OptionSet", "RawRepresentable",
    "Error", "Optional", "Any", "AnyObject", "Never",
    "Void", "Unicode", "Range", "ClosedRange", "CountableRange",
    "CountableClosedRange", "Date", "URL", "Data", "Data",
    "Result", "Task", "DispatchQueue"
  ],
  
  "builtins": [
    "print", "debugPrint", "dump", "assert", "precondition",
    "fatalError", "readLine", "stride", "zip", "min", "max",
    "abs", "pow", "sqrt", "sin", "cos", "tan", "log",
    "exp", "ceil", "floor", "round", "trunc", "fmod"
  ],
  
  "comments": {
    "single": "//",
    "multi_start": "/*",
    "multi_end": "*/"
  },
  
  "brackets": {
    "auto_close": ["(", "[", "{", "\"", "'"]
  },
  
  "indent": {
    "increase": ["{", "("],
    "decrease": ["}", ")"]
  },
  
  "completions": {
    "if": "if $1 {\n    $2\n}",
    "else": "else {\n    $1\n}",
    "guard": "guard $1 else {\n    $2\n    return\n}",
    "for": "for $1 in $2 {\n    $3\n}",
    "while": "while $1 {\n    $2\n}",
    "repeat": "repeat {\n    $1\n} while $2",
    "switch": "switch $1 {\ncase $2:\n    $3\ncase $4:\n    $5\ndefault:\n    $6\n}",
    "func": "func $1($2) -> $3 {\n    $4\n    return $5\n}",
    "struct": "struct $1 {\n    let $2: $3\n    var $4: $5\n    \n    init($6) {\n        self.$2 = $6\n    }\n}",
    "class": "class $1 {\n    let $2: $3\n    \n    init($4) {\n        self.$2 = $4\n    }\n    \n    func $5() -> $6 {\n        $7\n    }\n}",
    "protocol": "protocol $1 {\n    var $2: $3 { get set }\n    func $4() -> $5\n}",
    "extension": "extension $1 {\n    $2\n}",
    "enum": "enum $1 {\n    case $2\n    case $3\n}",
    "enum with value": "enum $1 {\n    case $2($3)\n    case $4($5)\n}",
    "let": "let $1: $2 = $3",
    "var": "var $1: $2 = $3",
    "lazy": "lazy var $1: $2 = { $3 }()",
    "computed": "var $1: $2 {\n    get { $3 }\n    set { $4 }\n}",
    "optional": "$1?",
    "unwrap": "if let $1 = $2 {\n    $3\n}",
    "guard let": "guard let $1 = $2 else {\n    $3\n    return\n}",
    "closure": "{ ($1) -> $2 in\n    $3\n}",
    "main": "import Foundation\n\nfunc main() {\n    $1\n}\n\nmain()",
    "do": "do {\n    try $1\n} catch {\n    $2\n}",
    "throw": "throw $1",
    "defer": "defer {\n    $1\n}"
  },
  
  "libraries": {
    "import Foundation": "",
    "import UIKit": "",
    "import SwiftUI": "",
    "import Combine": "",
    "import CoreData": "",
    "import CoreGraphics": "",
    "import QuartzCore": "",
    "import SceneKit": "",
    "import SpriteKit": "",
    "import Metal": "",
    "import MapKit": "",
    "import CoreLocation": "",
    "import AVFoundation": "",
    "import Photos": "",
    "import StoreKit": "",
    "import CloudKit": "",
    "import GameplayKit": "",
    "import CoreMotion": "",
    "import CoreImage": "",
    "import CoreML": "",
    "import ARKit": "",
    "import SwiftUI": "",
    "import Firebase": "-lFirebase",
    "import Alamofire": "-lAlamofire",
    "import SwiftyJSON": "-lSwiftyJSON",
    "import SDWebImage": "-lSDWebImage",
    "import RealmSwift": "-lRealmSwift"
  },
  
  "compile": {
    "build": "swiftc {file} -o {output} 2> compile_errors.txt",
    "run": "./{output}",
    "check": "swiftc -typecheck {file}"
  },
  
  "template": [
    "import Foundation",
    "",
    "func main() {",
    "    print(\"Hello, world!\")",
    "}",
    "",
    "main()"
  ],
  
  "help": {
    "short": "Swift: F7=Build F8=Run",
    "long": "Swift files (.swift)\nF7: Build with swiftc\nF8: Run the program\nTab: Auto-completion for Swift features"
  }
}