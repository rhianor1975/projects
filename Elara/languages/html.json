  "template": [
    "<!DOCTYPE html>",
    "<html lang=\"en\">",
    "<head>",
    "    <meta charset=\"UTF-8\">",
    "    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">",
    "    <title>My Page</title>",
    "    <style>",
    "        /* CSS Reset & Base Styles */",
    "        * {",
    "            margin: 0;",
    "            padding: 0;",
    "            box-sizing: border-box;",
    "        }",
    "        ",
    "        body {",
    "            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;",
    "            line-height: 1.6;",
    "            color: #333;",
    "            background-color: #f4f4f4;",
    "        }",
    "        ",
    "        .container {",
    "            max-width: 1200px;",
    "            margin: 0 auto;",
    "            padding: 0 20px;",
    "        }",
    "        ",
    "        header {",
    "            background: #333;",
    "            color: #fff;",
    "            padding: 1rem 0;",
    "        }",
    "        ",
    "        header h1 {",
    "            margin: 0;",
    "        }",
    "        ",
    "        nav ul {",
    "            list-style: none;",
    "            display: flex;",
    "            gap: 20px;",
    "        }",
    "        ",
    "        nav a {",
    "            color: #fff;",
    "            text-decoration: none;",
    "        }",
    "        ",
    "        main {",
    "            padding: 2rem 0;",
    "        }",
    "        ",
    "        footer {",
    "            background: #333;",
    "            color: #fff;",
    "            text-align: center;",
    "            padding: 1rem 0;",
    "            margin-top: 2rem;",
    "        }",
    "    </style>",
    "</head>",
    "<body>",
    "    <header>",
    "        <div class=\"container\">",
    "            <h1>My Website</h1>",
    "            <nav>",
    "                <ul>",
    "                    <li><a href=\"#\">Home</a></li>",
    "                    <li><a href=\"#\">About</a></li>",
    "                    <li><a href=\"#\">Services</a></li>",
    "                    <li><a href=\"#\">Contact</a></li>",
    "                </ul>",
    "            </nav>",
    "        </div>",
    "    </header>",
    "",
    "    <main>",
    "        <div class=\"container\">",
    "            <section>",
    "                <h2>Welcome</h2>",
    "                <p>Edit this content to build your page...</p>",
    "            </section>",
    "        </div>",
    "    </main>",
    "",
    "    <footer>",
    "        <div class=\"container\">",
    "            <p>&copy; 2024 My Website. All rights reserved.</p>",
    "        </div>",
    "    </footer>",
    "",
    "    <script>",
    "        // Main JavaScript",
    "        document.addEventListener('DOMContentLoaded', function() {",
    "            console.log('Page loaded');",
    "            ",
    "            // Your code here",
    "            const nav = document.querySelector('nav');",
    "            if (nav) {",
    "                // Navigation enhancements",
    "            }",
    "        });",
    "    </script>",
    "</body>",
    "</html>"
  ],
  
  "compile": {
    "build": "html-validate {file}",
    "run": "open {file}",
    "check": "html-validate {file} --config"
  },
  
  "help": {
    "short": "HTML with Embedded CSS/JS/Server-Side Languages",
    "long": "Full-featured HTML language support with embedded code highlighting and completions for:\n\nHTML5 Elements:\n- Semantic elements: header, nav, main, section, article, aside, footer\n- Media: video, audio, canvas, svg, figure\n- Forms: form, input, select, textarea, button, fieldset\n- Tables: table, thead, tbody, tr, td, th\n- Lists: ul, ol, li\n- Links and images: a, img\n\nCSS Features:\n- Style blocks with CSS syntax\n- Common patterns: flexbox, grid, media queries, animations\n- CSS completions: flex, grid, media, keyframes\n\nJavaScript Features:\n- Script blocks with JS syntax\n- DOM manipulation completions\n- Library detection: jQuery, Vue, React, Angular, etc.\n- JS patterns: DOM ready, functions, async operations\n\nServer-Side Languages:\n- ASP.NET WebForms: Page directives, controls, data binding\n- PHP: Standard PHP tags, loops, conditionals\n- Java JSP: JSTL tags, expressions\n- Python/Jinja: Template inheritance, loops, conditionals\n- Ruby/ERB: Embedded Ruby, form builders\n\nKey Shortcuts:\n- Tab: Complete tags and snippets\n- Ctrl+U: Insert page template\n- F7: Validate HTML\n- F8: Open in browser"
  }
}